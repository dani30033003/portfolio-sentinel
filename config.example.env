# Copy to .env and fill in real values. `.env` is gitignored — never commit secrets.

# --- IB Gateway (paper account) ---
# Consumed only by the ib-gateway container for IBC auto-login — the app never
# sees these directly, it talks to the gateway over the docker network.
IBKR_USERNAME=your-ibkr-paper-username
IBKR_PASSWORD=your-ibkr-paper-password
# Temporary — only needed to watch the gateway GUI over VNC during first login
# (2FA approval, paper-account setup). Pick any local password; not an IBKR credential.
IBKR_VNC_PASSWORD=change-me-local-only

# --- WhatsApp Cloud API (Meta) ---
# Leave these unset to run in dry-run mode: summaries print to the console instead.
WHATSAPP_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=000000000000000
# Recipient in E.164 digits, no plus sign (placeholder below, not a real number)
WHATSAPP_TO=15550000000
# Webhook verification handshake token — any string YOU invent; must match what
# you enter as "Verify token" in the Meta app dashboard webhook config.
WHATSAPP_VERIFY_TOKEN=pick-any-random-string
# Meta-issued app secret (dashboard -> App settings -> Basic -> App secret).
# Keys the HMAC signature check on every inbound webhook POST.
WHATSAPP_APP_SECRET=your-meta-app-secret
# Only needed to run `npm run webhook` (separate long-running process from
# the summary script). Port the Fastify webhook listener binds to.
# WEBHOOK_PORT=3000

# --- LLM (summaries/alerts writer) ---
# Leave all of this unset to skip the LLM: summaries stay plain numeric snapshots.
# LLM_PROVIDER is optional — inferred from whichever API key is set (anthropic wins).
# LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash
# LLM_TIMEOUT_MS=30000

# --- Storage ---
# SQLite file for snapshots/summaries. Local file, not a secret. The parent
# directory is created automatically. Default shown; uncomment to override.
# DB_PATH=./data/portfolio-sentinel.db

# --- Presentation ---
# Timezone used to format user-facing timestamps (storage is always UTC)
USER_TIMEZONE=Asia/Jerusalem
