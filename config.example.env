# Copy to .env and fill in real values. `.env` is gitignored — never commit secrets.

# --- WhatsApp Cloud API (Meta) ---
# Leave these unset to run in dry-run mode: summaries print to the console instead.
WHATSAPP_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=000000000000000
# Recipient in E.164 digits, no plus sign (placeholder below, not a real number)
WHATSAPP_TO=15550000000

# --- Presentation ---
# Timezone used to format user-facing timestamps (storage is always UTC)
USER_TIMEZONE=Asia/Jerusalem
